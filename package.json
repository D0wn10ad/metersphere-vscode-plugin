{
  "name": "metersphere-vscode-extension",
  "displayName": "MeterSphere VSCode",
  "description": "VSCode extension to interact with MeterSphere v2 APIs (Phase 1 MVP + Phase 2 Navigator)",
  "version": "0.1.0",
  "publisher": "metersphere",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "*",
    "onCommand:metersphere.openDebugger",
    "onCommand:metersphere.refreshNavigator",
    "onCommand:metersphere.openNavigator",
    "onCommand:metersphere.prefillFromNode",
    "onCommand:metersphere.testConnection",
    "onCommand:metersphere.statusBarMenu",
    "onCommand:metersphere.configure"
  ],
  "main": "out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "metersphere-sidebar",
          "title": "MeterSphere",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "metersphere-sidebar": [
        {
          "id": "metersphere.navigator",
          "name": "Navigator",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "MeterSphere",
      "properties": {
        "metersphere.msUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "MeterSphere server URL"
        },
        "metersphere.accessKey": {
          "type": "string",
          "default": "",
          "description": "MeterSphere Access Key (from User Settings → Token)"
        },
        "metersphere.secretKey": {
          "type": "string",
          "default": "",
          "description": "MeterSphere Secret Key (from User Settings → Token)"
        },
        "metersphere.workspaceId": {
          "type": "string",
          "default": "",
          "description": "Selected MeterSphere workspace ID (auto-synced from Navigator)"
        },
        "metersphere.projectId": {
          "type": "string",
          "default": "",
          "description": "Selected MeterSphere project ID (auto-synced from Navigator)"
        },
        "metersphere.debugEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to Output panel"
        }
      }
    },
    "commands": [
      {
        "command": "metersphere.openDebugger",
        "title": "MeterSphere: Open Debugger"
      },
      {
        "command": "metersphere.refreshNavigator",
        "title": "MeterSphere: Refresh Navigator"
      },
      {
        "command": "metersphere.openNavigator",
        "title": "MeterSphere: Open Navigator"
      },
      {
        "command": "metersphere.prefillFromNode",
        "title": "MeterSphere: Prefill from Node"
      },
      {
        "command": "metersphere.configure",
        "title": "MeterSphere: Configure"
      },
      {
        "command": "metersphere.testConnection",
        "title": "MeterSphere: Test Connection"
      },
      {
        "command": "metersphere.statusBarMenu",
        "title": "MeterSphere: Status Bar Menu"
      },
      {
        "command": "metersphere.toggleDebug",
        "title": "MeterSphere: Toggle Debug Mode"
      },
      {
        "command": "metersphere.uploadFromEditor",
        "title": "MeterSphere: Upload to MeterSphere"
      },
      {
        "command": "metersphere.uploadFromFileExplorer",
        "title": "MeterSphere: Upload to MeterSphere"
      },
      {
        "command": "metersphere.showEnvironment",
        "title": "Show Environment",
        "icon": "$(globe)"
      },
      {
        "command": "metersphere.showHistory",
        "title": "Show History",
        "icon": "$(history)"
      },
      {
        "command": "metersphere.showSettings",
        "title": "Show Settings",
        "icon": "$(settings)"
      },
      {
        "command": "metersphere.showSync",
        "title": "Show Sync",
        "icon": "$(sync)"
      },
      {
        "command": "metersphere.syncToMs",
        "title": "MeterSphere: Sync to MeterSphere"
      },
      {
        "command": "metersphere.uploadFromNavigator",
        "title": "MeterSphere: Upload to MeterSphere"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "metersphere.uploadFromEditor",
          "group": "meterSphere@1"
        }
      ],
      "filesExplorer/context": [
        {
          "command": "metersphere.uploadFromFileExplorer",
          "group": "meterSphere@1"
        }
      ],
      "view/title": [
        {
          "command": "metersphere.showEnvironment",
          "when": "view == metersphere.navigator",
          "group": "navigation@1",
          "icon": "$(globe)"
        },
        {
          "command": "metersphere.showHistory",
          "when": "view == metersphere.navigator",
          "group": "navigation@2",
          "icon": "$(history)"
        },
        {
          "command": "metersphere.showSync",
          "when": "view == metersphere.navigator",
          "group": "navigation@3",
          "icon": "$(sync)"
        },
        {
          "command": "metersphere.showSettings",
          "when": "view == metersphere.navigator",
          "group": "navigation@4",
          "icon": "$(settings)"
        }
      ],
      "view/item/context": [
        {
          "command": "metersphere.uploadFromNavigator",
          "when": "view == metersphere.navigator",
          "group": "meterSphere@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "test": "jest"
  },
  "dependencies": {
    "form-data": "^4.0.5",
    "asynckit": "^0.4.0"
  },
  "devDependencies": {
    "typescript": "^4.9.5",
    "@types/node": "^20.11.7",
    "ts-node": "^10.9.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  }
}
